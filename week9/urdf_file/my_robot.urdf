<?xml version="1.0"?>
<robot name="my_custom_robot">

  <!-- ==================== MATERIALS ==================== -->
  <material name="blue">
    <color rgba="0.0 0.2 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="0.9 0.8 0.0 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.7 0.2 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <!--
    base_link frame sits at Z=0 (ground plane).
    The base box is lifted so its bottom sits ON the wheel axles:
      base bottom  = wheel_radius = 0.065 m
      base center  = 0.065 + 0.075 = 0.140 m
      base top     = 0.065 + 0.150 = 0.215 m
    All child joint origins are measured from base_link (Z=0 = ground).
  -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.140" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.35 0.15"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.140" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.35 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.140" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.06042" ixy="0.0" ixz="0.0"
               iyy="0.11354" iyz="0.0"
               izz="0.15521"/>
    </inertial>
  </link>

  <!-- ==================== LEFT WHEEL ==================== -->
  <!--
    Wheel r=0.065 m touches ground at Z=0, so wheel centre = Z=0.065.
    Y=+0.195 = half base width (0.175) + half wheel thickness (0.02).
    RPY=-pi/2 aligns the cylinder axis with world Y; axis="0 0 1" spins around that.
  -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.195 0.065" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000595" ixy="0.0" ixz="0.0"
               iyy="0.000595" iyz="0.0"
               izz="0.001056"/>
    </inertial>
  </link>

  <!-- ==================== RIGHT WHEEL ==================== -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.195 0.065" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.065" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000595" ixy="0.0" ixz="0.0"
               iyy="0.000595" iyz="0.0"
               izz="0.001056"/>
    </inertial>
  </link>

  <!-- ==================== FRONT CASTER ==================== -->
  <!--
    Sphere r=0.030 m. Centre at Z=0.030 → bottom at Z=0 (touching ground).
    Caster top = 0.060, base bottom = 0.065 → caster sits just below the base. Visible.
  -->
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.18 0.0 0.030" rpy="0 0 0"/>
  </joint>

  <link name="front_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <!-- 2mr^2/5 = 2*0.05*0.0009/5 -->
      <inertia ixx="0.000018" ixy="0.0" ixz="0.0"
               iyy="0.000018" iyz="0.0"
               izz="0.000018"/>
    </inertial>
  </link>

  <!-- ==================== REAR CASTER ==================== -->
  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster"/>
    <origin xyz="-0.18 0.0 0.030" rpy="0 0 0"/>
  </joint>

  <link name="rear_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.030"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000018" ixy="0.0" ixz="0.0"
               iyy="0.000018" iyz="0.0"
               izz="0.000018"/>
    </inertial>
  </link>

  <!-- ==================== LIDAR MOUNT ==================== -->
  <!--
    Box 0.08×0.08×0.04 on top of base.
    z = base_top + half_mount = 0.215 + 0.020 = 0.235
  -->
  <joint name="lidar_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_mount"/>
    <origin xyz="0.0 0.0 0.235" rpy="0 0 0"/>
  </joint>

  <link name="lidar_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000073" ixy="0.0" ixz="0.0"
               iyy="0.000073" iyz="0.0"
               izz="0.000107"/>
    </inertial>
  </link>

  <!-- ==================== LIDAR SENSOR ==================== -->
  <!-- z = half_mount + half_lidar = 0.020 + 0.025 = 0.045 (relative to lidar_mount) -->
  <joint name="lidar_joint" type="fixed">
    <parent link="lidar_mount"/>
    <child link="lidar"/>
    <origin xyz="0.0 0.0 0.045" rpy="0 0 0"/>
  </joint>

  <link name="lidar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000167" ixy="0.0" ixz="0.0"
               iyy="0.000167" iyz="0.0"
               izz="0.000250"/>
    </inertial>
  </link>

  <!-- ==================== CAMERA MOUNT ==================== -->
  <!--
    Box 0.04×0.04×0.06 at the front face of base.
    x = base_front + half_mount = 0.250 + 0.020 = 0.270
    z = base_center_height = 0.140
  -->
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount"/>
    <origin xyz="0.27 0.0 0.140" rpy="0 0 0"/>
  </joint>

  <link name="camera_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.06"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000024" ixy="0.0" ixz="0.0"
               iyy="0.000024" iyz="0.0"
               izz="0.000013"/>
    </inertial>
  </link>

  <!-- ==================== CAMERA ==================== -->
  <!-- Cylinder pointing forward (+X). RPY="0 pi/2 0" aligns cylinder Z with world +X. -->
  <joint name="camera_joint" type="fixed">
    <parent link="camera_mount"/>
    <child link="camera"/>
    <origin xyz="0.03 0.0 0.0" rpy="0 1.5708 0"/>
  </joint>

  <link name="camera">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000008" ixy="0.0" ixz="0.0"
               iyy="0.000008" iyz="0.0"
               izz="0.000010"/>
    </inertial>
  </link>

  <!-- ==================== ARM BASE ==================== -->
  <!--
    Box 0.06×0.06×0.08 on the rear-top of base.
    x = -0.18, z = base_top + half_arm_base = 0.215 + 0.040 = 0.255
  -->
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="-0.18 0.0 0.255" rpy="0 0 0"/>
  </joint>

  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000340" ixy="0.0" ixz="0.0"
               iyy="0.000340" iyz="0.0"
               izz="0.000180"/>
    </inertial>
  </link>

  <!-- ==================== ARM UPPER (shoulder revolute) ==================== -->
  <!--
    Box 0.05×0.05×0.15. Revolute about Y-axis, ±90 degrees.
    Joint at top of arm_base: z = half_arm_base + half_upper = 0.040 + 0.075 = 0.115.
    Visual offset +0.075 in Z so joint sits at the BOTTOM of the segment.
  -->
  <joint name="arm_upper_joint" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_upper"/>
    <origin xyz="0.0 0.0 0.115" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="arm_upper">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.000833" ixy="0.0" ixz="0.0"
               iyy="0.000833" iyz="0.0"
               izz="0.000167"/>
    </inertial>
  </link>

  <!-- ==================== ARM LOWER (elbow revolute) ==================== -->
  <!--
    Box 0.05×0.05×0.12. Revolute about Y-axis, ±120 degrees.
    Joint at tip of arm_upper segment (z=0.15 relative to arm_upper frame).
    Visual offset +0.06 in Z.
  -->
  <joint name="arm_lower_joint" type="revolute">
    <parent link="arm_upper"/>
    <child link="arm_lower"/>
    <origin xyz="0.0 0.0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="8.0" velocity="1.0"/>
  </joint>

  <link name="arm_lower">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.12"/>
      </geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000423" ixy="0.0" ixz="0.0"
               iyy="0.000423" iyz="0.0"
               izz="0.000125"/>
    </inertial>
  </link>

  <!-- ==================== GRIPPER BASE (wrist) ==================== -->
  <!-- Sphere r=0.04 at the tip of arm_lower (z=0.12 above arm_lower origin). -->
  <joint name="gripper_joint" type="fixed">
    <parent link="arm_lower"/>
    <child link="gripper_base"/>
    <origin xyz="0.0 0.0 0.12" rpy="0 0 0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000096" ixy="0.0" ixz="0.0"
               iyy="0.000096" iyz="0.0"
               izz="0.000096"/>
    </inertial>
  </link>

</robot>
